{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "void_meridian_master_schema_v1",
  "title": "VOID: The Unseen Hand — Meridian_Master.json Schema",
  "description": "Validates the single manifest file imported by the VOID World Builder. Defines structure only; does not constrain narrative content, which remains authoritative in the five approved district packages.",
  "type": "object",
  "required": [
    "$schema",
    "project_metadata",
    "canon_lock",
    "registry_references",
    "generation_pipeline",
    "package_dependencies",
    "builder_configuration",
    "generation_settings",
    "performance_settings",
    "streaming_settings",
    "world_scale_metadata",
    "traversal_metadata",
    "gameplay_metadata",
    "district_metadata",
    "version_compatibility",
    "future_expansion_rules",
    "flagged_open_items",
    "validation_rules"
  ],
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string",
      "const": "void_meridian_master_schema_v1"
    },
    "project_metadata": {
      "type": "object",
      "required": ["project_name", "canon_version", "package_version", "build_version", "generation_version", "author", "creation_date", "last_revision", "status"],
      "additionalProperties": false,
      "properties": {
        "project_name": { "type": "string", "minLength": 1 },
        "canon_version": { "type": "string", "minLength": 1 },
        "package_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "build_version": { "type": "string", "minLength": 1 },
        "generation_version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
        "author": { "type": "string", "minLength": 1 },
        "creation_date": { "type": "string", "format": "date" },
        "last_revision": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["draft", "approved_pending_supporting_registries", "approved", "complete"] }
      }
    },
    "canon_lock": {
      "type": "object",
      "required": ["locked_sources", "locked_packages", "modification_policy", "authority_rule"],
      "additionalProperties": false,
      "properties": {
        "locked_sources": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" }
        },
        "locked_packages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "files", "status"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "files": {
                "type": "array",
                "minItems": 1,
                "items": { "type": "string" }
              },
              "status": { "type": "string", "enum": ["approved", "pending", "deprecated"] }
            }
          }
        },
        "modification_policy": { "type": "string", "minLength": 1 },
        "authority_rule": { "type": "string", "minLength": 1 }
      }
    },
    "registry_references": {
      "type": "object",
      "minProperties": 12,
      "additionalProperties": {
        "type": "object",
        "required": ["file", "required"],
        "additionalProperties": false,
        "properties": {
          "file": { "type": "string", "pattern": "^[A-Za-z0-9_]+\\.(json|md)$" },
          "required": { "type": "boolean" }
        }
      }
    },
    "generation_pipeline": {
      "type": "object",
      "required": ["import_order", "generation_order", "module_dependencies"],
      "additionalProperties": false,
      "properties": {
        "import_order": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "generation_order": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["step", "target", "role", "depends_on"],
            "additionalProperties": false,
            "properties": {
              "step": { "type": "integer", "minimum": 1 },
              "target": { "type": "string", "minLength": 1 },
              "role": { "type": "string", "minLength": 1 },
              "depends_on": {
                "type": "array",
                "items": { "type": "string" }
              }
            }
          }
        },
        "module_dependencies": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "package_dependencies": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["requires", "produces_context_for"],
        "additionalProperties": false,
        "properties": {
          "requires": {
            "type": "array",
            "items": { "type": "string" }
          },
          "produces_context_for": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    },
    "builder_configuration": {
      "type": "object",
      "required": ["single_import_file", "builder_must_not_manually_import_other_files", "geometry_calculation_authority", "manifest_authority", "coordinate_policy", "extensibility_policy"],
      "additionalProperties": false,
      "properties": {
        "single_import_file": { "type": "string", "minLength": 1 },
        "builder_must_not_manually_import_other_files": { "type": "boolean", "const": true },
        "geometry_calculation_authority": { "type": "string", "minLength": 1 },
        "manifest_authority": { "type": "string", "minLength": 1 },
        "coordinate_policy": { "type": "string", "minLength": 1 },
        "extensibility_policy": { "type": "string", "minLength": 1 }
      }
    },
    "generation_settings": {
      "type": "object",
      "required": ["generation_mode", "allow_parallel_generation_within_step", "allow_parallel_generation_across_steps", "regeneration_policy"],
      "additionalProperties": false,
      "properties": {
        "generation_mode": { "type": "string", "minLength": 1 },
        "allow_parallel_generation_within_step": { "type": "boolean" },
        "allow_parallel_generation_across_steps": { "type": "boolean" },
        "regeneration_policy": { "type": "string", "minLength": 1 }
      }
    },
    "performance_settings": {
      "type": "object",
      "required": ["streaming_priority_policy", "cheapest_districts_reference", "highest_density_districts_reference", "dynamic_state_districts_reference", "notes"],
      "additionalProperties": false,
      "properties": {
        "streaming_priority_policy": { "type": "string", "minLength": 1 },
        "cheapest_districts_reference": { "type": "array", "items": { "type": "string" } },
        "highest_density_districts_reference": { "type": "array", "items": { "type": "string" } },
        "dynamic_state_districts_reference": { "type": "array", "items": { "type": "string" } },
        "notes": { "type": "string" }
      }
    },
    "streaming_settings": {
      "type": "object",
      "required": ["world_partition_regions", "connective_tissue_streaming", "reusable_templates", "single_instance_regions"],
      "additionalProperties": false,
      "properties": {
        "world_partition_regions": { "type": "array", "minItems": 1, "items": { "type": "string", "pattern": "^WP_" } },
        "connective_tissue_streaming": { "type": "string", "minLength": 1 },
        "reusable_templates": { "type": "array", "items": { "type": "string" } },
        "single_instance_regions": { "type": "array", "items": { "type": "string" } }
      }
    },
    "world_scale_metadata": {
      "type": "object",
      "required": ["canon_confirmed_population", "source", "fabricated_values_policy", "radial_bands", "vertical_tiers"],
      "additionalProperties": false,
      "properties": {
        "canon_confirmed_population": { "type": "string", "minLength": 1 },
        "source": { "type": "string", "minLength": 1 },
        "fabricated_values_policy": { "type": "string", "minLength": 1 },
        "radial_bands": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "vertical_tiers": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    },
    "traversal_metadata": {
      "type": "object",
      "required": ["network_model", "networks", "rooftop_traversal_scope", "vehicle_synchronization_scope"],
      "additionalProperties": false,
      "properties": {
        "network_model": { "type": "string", "minLength": 1 },
        "networks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["id", "type", "coverage", "serves"],
            "additionalProperties": false,
            "properties": {
              "id": { "type": "string" },
              "type": { "type": "string" },
              "coverage": { "type": "string" },
              "serves": { "type": "array", "items": { "type": "string" } }
            }
          }
        },
        "rooftop_traversal_scope": { "type": "array", "items": { "type": "string" } },
        "vehicle_synchronization_scope": { "type": "string" }
      }
    },
    "gameplay_metadata": {
      "type": "object",
      "required": ["district_gameplay_registers", "register_overlap_policy", "combat_policy_by_district"],
      "additionalProperties": false,
      "properties": {
        "district_gameplay_registers": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["district", "register"],
            "additionalProperties": false,
            "properties": {
              "district": { "type": "string" },
              "register": { "type": "string" }
            }
          }
        },
        "register_overlap_policy": { "type": "string" },
        "combat_policy_by_district": {
          "type": "object",
          "additionalProperties": { "type": "string" }
        }
      }
    },
    "district_metadata": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["id", "data_reference", "radial_position", "vertical_position", "build_order_index"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "enum": ["undercroft", "white_zones", "metro_archives", "sector_0", "olympus_spire"] },
          "data_reference": { "type": "string", "pattern": "\\.json$" },
          "radial_position": { "type": "string", "minLength": 1 },
          "vertical_position": { "type": "string", "minLength": 1 },
          "build_order_index": { "type": "integer", "minimum": 1, "maximum": 5 }
        }
      }
    },
    "version_compatibility": {
      "type": "object",
      "required": ["meridian_master_schema", "district_data_schema", "requires_all_five_district_packages_at_schema", "backward_compatibility_policy"],
      "additionalProperties": false,
      "properties": {
        "meridian_master_schema": { "type": "string" },
        "district_data_schema": { "type": "string" },
        "requires_all_five_district_packages_at_schema": { "type": "string" },
        "backward_compatibility_policy": { "type": "string" }
      }
    },
    "future_expansion_rules": {
      "type": "object",
      "required": ["phase_2_scope", "phase_3_scope", "new_district_registration_policy", "new_district_review_gate"],
      "additionalProperties": false,
      "properties": {
        "phase_2_scope": { "type": "string" },
        "phase_3_scope": { "type": "string" },
        "new_district_registration_policy": { "type": "string" },
        "new_district_review_gate": { "type": "string" }
      }
    },
    "flagged_open_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "priority", "source_package", "status", "blocks"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string", "minLength": 1 },
          "priority": { "type": "string", "enum": ["highest_in_project", "moderate", "low"] },
          "source_package": { "type": "string", "enum": ["undercroft", "white_zones", "metro_archives", "sector_0", "olympus_spire"] },
          "status": { "type": "string" },
          "blocks": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "validation_rules": {
      "type": "object",
      "required": ["pre_generation_checks", "post_generation_checks", "validation_report_target"],
      "additionalProperties": false,
      "properties": {
        "pre_generation_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "post_generation_checks": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "validation_report_target": { "type": "string" }
      }
    }
  }
}
