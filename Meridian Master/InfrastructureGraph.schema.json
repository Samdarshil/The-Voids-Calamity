{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "void_infrastructure_graph_schema_v1",
  "title": "VOID: The Unseen Hand — InfrastructureGraph.json Schema",
  "type": "object",
  "required": ["$schema", "utility_categories", "communications_backbone", "power_infrastructure", "water_and_climate_control", "maintenance_and_support_systems", "waste_and_resource_management", "repurposed_infrastructure_cases", "infrastructure_hierarchy_by_district", "cross_reference_note"],
  "additionalProperties": false,
  "properties": {
    "$schema": { "type": "string", "const": "void_infrastructure_graph_schema_v1" },
    "utility_categories": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "communications_backbone": {
      "type": "object",
      "required": ["system_id", "description", "canon_source", "single_backbone_rule", "coverage_by_district"],
      "additionalProperties": false,
      "properties": {
        "system_id": { "type": "string" },
        "description": { "type": "string" },
        "canon_source": { "type": "string" },
        "single_backbone_rule": { "type": "string" },
        "coverage_by_district": {
          "type": "array",
          "minItems": 5,
          "maxItems": 5,
          "items": {
            "type": "object",
            "required": ["district", "is_off_weave", "coverage_density", "source"],
            "additionalProperties": false,
            "properties": {
              "district": { "type": "string" },
              "is_off_weave": { "type": "boolean" },
              "coverage_density": { "type": "string" },
              "source": { "type": "string" }
            }
          }
        }
      }
    },
    "power_infrastructure": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["district", "service_tier", "source"],
        "additionalProperties": false,
        "properties": {
          "district": { "type": "string" },
          "service_tier": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "water_and_climate_control": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["district", "service_tier", "notes"],
        "additionalProperties": false,
        "properties": {
          "district": { "type": "string" },
          "service_tier": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    },
    "maintenance_and_support_systems": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["district", "model", "characterization", "source"],
        "additionalProperties": false,
        "properties": {
          "district": { "type": "string" },
          "model": { "type": "string" },
          "characterization": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "waste_and_resource_management": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["district", "model"],
        "additionalProperties": false,
        "properties": {
          "district": { "type": "string" },
          "model": { "type": "string" },
          "source": { "type": "string" }
        }
      }
    },
    "repurposed_infrastructure_cases": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "district", "repurposed_systems", "repurposed_for", "canon_status", "source", "hard_constraint"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "district": { "type": "string" },
          "repurposed_systems": { "type": "array", "items": { "type": "string" } },
          "repurposed_for": { "type": "string" },
          "canon_status": { "type": "string" },
          "source": { "type": "string" },
          "hard_constraint": { "type": "string" }
        }
      }
    },
    "infrastructure_hierarchy_by_district": {
      "type": "array",
      "minItems": 5,
      "maxItems": 5,
      "items": {
        "type": "object",
        "required": ["rank", "district", "overall_tier"],
        "additionalProperties": false,
        "properties": {
          "rank": { "type": "integer", "minimum": 1, "maximum": 5 },
          "district": { "type": "string" },
          "overall_tier": { "type": "string" }
        }
      }
    },
    "cross_reference_note": { "type": "string" }
  }
}
